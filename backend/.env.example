# Database
DATABASE_URL=postgresql+psycopg2://ai_sdlc_user:password@localhost:5432/ai_sdlc

# App
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production
# In production set APP_DEBUG=false and list allowed origins here (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Ollama (default LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# RAG embedding model — pull with: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (optional)
OPENAI_API_KEY=
