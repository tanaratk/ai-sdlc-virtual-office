{
  "version": "2.0.0",
  "description": "Unified contracts for the AI-SDLC 3-layer pipeline and on-demand agents.",
  "agents": [
    {
      "id": "requirement-agent",
      "name": "Requirement Agent",
      "role": "requirement_analyst",
      "layer": "business",
      "step": { "name": "requirement_summary", "order": 1, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": [], "optional_documents": [], "runtime_inputs": ["requirement_inputs"] },
      "outputs": { "documents": ["requirement_summary"], "workspace_files": ["docs/requirement_summary.md"] },
      "responsibilities": ["Normalize raw requirement inputs", "Extract FR/NFR/business rules", "Identify assumptions, constraints, and open questions"],
      "handoff": { "next_agent": "gap-analysis-agent", "review_gate": false, "failure_action": "mark pipeline failed and notify user" },
      "workspace": { "home_zone": "requirement_room", "writes_to": ["docs/requirement_summary.md"] }
    },
    {
      "id": "gap-analysis-agent",
      "name": "Gap Analysis Agent",
      "role": "gap_analyst",
      "layer": "business",
      "step": { "name": "gap_analysis", "order": 2, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["requirement_summary"], "optional_documents": [], "runtime_inputs": [] },
      "outputs": { "documents": ["gap_analysis_report"], "workspace_files": ["docs/gap_analysis_report.md"] },
      "responsibilities": ["Score requirement completeness", "List gaps and clarification questions", "Recommend fixes before BA analysis"],
      "handoff": { "next_agent": "ba-agent", "review_gate": true, "failure_action": "mark step failed and preserve requirement summary" },
      "workspace": { "home_zone": "gap_analysis_room", "writes_to": ["docs/gap_analysis_report.md"] }
    },
    {
      "id": "ba-agent",
      "name": "BA Agent",
      "role": "business_analyst",
      "layer": "business",
      "step": { "name": "ba_documents", "order": 3, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["requirement_summary", "gap_analysis_report"], "optional_documents": [], "runtime_inputs": [] },
      "outputs": { "documents": ["brd", "fsd", "user_story"], "workspace_files": ["docs/brd.md", "docs/fsd.md", "docs/user_story.md"] },
      "responsibilities": ["Create BRD", "Create FSD", "Create user stories with acceptance criteria", "Maintain traceability to FR IDs"],
      "handoff": { "next_agent": "architect-agent", "review_gate": true, "failure_action": "mark business gate failed" },
      "workspace": { "home_zone": "ba_room", "writes_to": ["docs/brd.md", "docs/fsd.md", "docs/user_story.md"] }
    },
    {
      "id": "architect-agent",
      "name": "Solution Architect Agent",
      "role": "solution_architect",
      "layer": "design",
      "step": { "name": "sa_documents", "order": 4, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["brd", "fsd", "user_story"], "optional_documents": ["requirement_summary"], "runtime_inputs": [] },
      "outputs": { "documents": ["architecture_design", "database_design", "api_spec"], "workspace_files": ["docs/architecture_design.md", "docs/database_design.md", "docs/api_spec.md"] },
      "responsibilities": ["Define architecture components", "Design database schema", "Define API contracts", "Map design outputs to FSD and FR references"],
      "handoff": { "next_agent": "ux-agent", "review_gate": true, "failure_action": "mark design step failed" },
      "workspace": { "home_zone": "sa_room", "writes_to": ["docs/architecture_design.md", "docs/database_design.md", "docs/api_spec.md"] }
    },
    {
      "id": "ux-agent",
      "name": "UX Agent",
      "role": "ux_designer",
      "layer": "design",
      "step": { "name": "ux_documents", "order": 5, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["brd", "fsd", "user_story"], "optional_documents": ["api_spec"], "runtime_inputs": [] },
      "outputs": { "documents": ["screen_spec"], "workspace_files": ["docs/screen_spec.md"] },
      "responsibilities": ["Define screens and UI flows", "Map screens to user stories", "Identify UI fields, actions, validation, and API dependencies"],
      "handoff": { "next_agent": "technical-design-agent", "review_gate": true, "failure_action": "mark UX step failed" },
      "workspace": { "home_zone": "ux_studio", "writes_to": ["docs/screen_spec.md"] }
    },
    {
      "id": "technical-design-agent",
      "name": "Technical Design Agent",
      "role": "technical_designer",
      "layer": "design",
      "step": { "name": "technical_design", "order": 6, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["fsd", "architecture_design", "database_design", "api_spec", "screen_spec"], "optional_documents": ["user_story"], "runtime_inputs": [] },
      "outputs": { "documents": ["technical_design"], "workspace_files": ["docs/dev_tasks.md"] },
      "responsibilities": ["Produce implementation task table", "Recommend developer fan-out count", "Define file paths and dependencies"],
      "handoff": { "next_agent": "developer-agent", "review_gate": true, "failure_action": "block delivery layer" },
      "workspace": { "home_zone": "developer_zone", "writes_to": ["docs/dev_tasks.md"] }
    },
    {
      "id": "developer-agent",
      "name": "Developer Agent Orchestrator",
      "role": "developer",
      "layer": "delivery",
      "step": { "name": "dev_tasks", "order": 7, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["technical_design", "fsd", "architecture_design", "database_design", "api_spec", "screen_spec"], "optional_documents": ["user_story"], "runtime_inputs": ["developer_instances"] },
      "outputs": { "documents": ["code_task_list"], "workspace_files": ["generated_app/**"] },
      "responsibilities": ["Generate source files", "Fan out work across developer lanes", "Preserve cross-file import consistency", "Summarize generated files and failures"],
      "handoff": { "next_agent": "code-review-agent", "review_gate": true, "failure_action": "mark generated code step failed" },
      "workspace": { "home_zone": "developer_zone", "writes_to": ["generated_app/**"] }
    },
    {
      "id": "developer-agent-backend",
      "name": "Backend Developer Agent",
      "role": "backend_developer",
      "layer": "delivery",
      "step": { "name": "dev_tasks", "order": 7, "total": 11, "auto_chain": false },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["technical_design"], "optional_documents": ["api_spec", "database_design"], "runtime_inputs": ["backend_lane_files"] },
      "outputs": { "documents": [], "workspace_files": ["generated_app/backend/**"] },
      "responsibilities": ["Generate backend models, schemas, routes, and migrations", "Keep backend contracts consistent with API and database design"],
      "handoff": { "next_agent": "developer-agent", "review_gate": false, "failure_action": "report lane failure to orchestrator" },
      "workspace": { "home_zone": "developer_zone", "writes_to": ["generated_app/backend/**"] }
    },
    {
      "id": "developer-agent-frontend",
      "name": "Frontend Developer Agent",
      "role": "frontend_developer",
      "layer": "delivery",
      "step": { "name": "dev_tasks", "order": 7, "total": 11, "auto_chain": false },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["technical_design"], "optional_documents": ["screen_spec", "api_spec"], "runtime_inputs": ["frontend_lane_files"] },
      "outputs": { "documents": [], "workspace_files": ["generated_app/frontend/**"] },
      "responsibilities": ["Generate React pages, components, types, and API clients", "Keep UI behavior aligned with screen spec"],
      "handoff": { "next_agent": "developer-agent", "review_gate": false, "failure_action": "report lane failure to orchestrator" },
      "workspace": { "home_zone": "developer_zone", "writes_to": ["generated_app/frontend/**"] }
    },
    {
      "id": "developer-agent-platform",
      "name": "Platform Developer Agent",
      "role": "platform_developer",
      "layer": "delivery",
      "step": { "name": "dev_tasks", "order": 7, "total": 11, "auto_chain": false },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["technical_design"], "optional_documents": ["architecture_design"], "runtime_inputs": ["platform_lane_files"] },
      "outputs": { "documents": [], "workspace_files": ["generated_app/README.md", "generated_app/.env.example", "generated_app/tests/**"] },
      "responsibilities": ["Generate config, README, env examples, tests, and cross-cutting project files"],
      "handoff": { "next_agent": "developer-agent", "review_gate": false, "failure_action": "report lane failure to orchestrator" },
      "workspace": { "home_zone": "developer_zone", "writes_to": ["generated_app/README.md", "generated_app/.env.example", "generated_app/tests/**"] }
    },
    {
      "id": "code-review-agent",
      "name": "Code Review Agent",
      "role": "code_reviewer",
      "layer": "delivery",
      "step": { "name": "code_review", "order": 8, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["code_task_list"], "optional_documents": ["technical_design"], "runtime_inputs": ["generated_app_source"] },
      "outputs": { "documents": ["code_review"], "workspace_files": ["docs/code_review.md"] },
      "responsibilities": ["Review generated source for defects", "Check task completeness", "Report severity, file path, and remediation guidance"],
      "handoff": { "next_agent": "qa-agent", "review_gate": true, "failure_action": "mark code review failed" },
      "workspace": { "home_zone": "developer_zone", "writes_to": ["docs/code_review.md"] }
    },
    {
      "id": "qa-agent",
      "name": "QA Agent",
      "role": "qa_engineer",
      "layer": "delivery",
      "step": { "name": "test_cases", "order": 9, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["api_spec", "screen_spec"], "optional_documents": ["code_review", "user_story"], "runtime_inputs": ["generated_app_source"] },
      "outputs": { "documents": ["test_report"], "workspace_files": ["generated_app/tests/**", "docs/test_report.md"] },
      "responsibilities": ["Generate executable tests", "Run available pytest and Playwright checks", "Capture stdout, stderr, and pass/fail summary"],
      "handoff": { "next_agent": "devops-agent", "review_gate": true, "failure_action": "mark QA step failed" },
      "workspace": { "home_zone": "qa_lab", "writes_to": ["generated_app/tests/**", "docs/test_report.md"] }
    },
    {
      "id": "devops-agent",
      "name": "DevOps Agent",
      "role": "devops_engineer",
      "layer": "delivery",
      "step": { "name": "devops_tasks", "order": 10, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "coder14b:latest" },
      "inputs": { "required_documents": ["architecture_design", "database_design", "api_spec", "fsd"], "optional_documents": ["test_report"], "runtime_inputs": ["generated_app_source"] },
      "outputs": { "documents": ["devops_config", "build_report"], "workspace_files": ["generated_app/Dockerfile.backend", "generated_app/Dockerfile.frontend", "generated_app/docker-compose.yml", "docs/build_report.md"] },
      "responsibilities": ["Generate Docker and CI/CD files", "Run Docker config/build/deploy when available", "Health check and rollback on failure"],
      "handoff": { "next_agent": "monitoring-agent", "review_gate": true, "failure_action": "mark DevOps step failed" },
      "workspace": { "home_zone": "devops_room", "writes_to": ["generated_app/docker-compose.yml", "docs/build_report.md"] }
    },
    {
      "id": "monitoring-agent",
      "name": "Monitoring Agent",
      "role": "monitoring_engineer",
      "layer": "delivery",
      "step": { "name": "monitoring", "order": 11, "total": 11, "auto_chain": true },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["build_report"], "optional_documents": ["api_spec"], "runtime_inputs": ["running_services"] },
      "outputs": { "documents": ["monitoring_report"], "workspace_files": ["docs/monitoring_report.md"] },
      "responsibilities": ["Inspect Docker Compose status and logs", "Probe common health endpoints", "Produce initial monitoring report"],
      "handoff": { "next_agent": null, "review_gate": true, "failure_action": "mark monitoring step failed" },
      "workspace": { "home_zone": "monitoring_room", "writes_to": ["docs/monitoring_report.md"] }
    },
    {
      "id": "change-impact-agent",
      "name": "Change Impact Agent",
      "role": "change_analyst",
      "layer": "on_demand",
      "step": { "name": "change_impact", "order": 0, "total": 11, "auto_chain": false },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": ["requirement_summary"], "optional_documents": ["fsd", "api_spec", "database_design", "screen_spec", "test_cases"], "runtime_inputs": ["change_description", "changed_requirement_ids"] },
      "outputs": { "documents": ["change_impact_report"], "workspace_files": ["docs/change_impact_report.md"] },
      "responsibilities": ["Analyze requirement changes", "List impacted documents/code/tests", "Estimate rework and risk"],
      "handoff": { "next_agent": null, "review_gate": true, "failure_action": "return impact error without changing pipeline state" },
      "workspace": { "home_zone": "change_impact_room", "writes_to": ["docs/change_impact_report.md"] }
    },
    {
      "id": "documentation-agent",
      "name": "Documentation Agent",
      "role": "documentation_manager",
      "layer": "on_demand",
      "step": { "name": "documentation", "order": 0, "total": 11, "auto_chain": false },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": [], "optional_documents": ["requirement_summary", "brd", "fsd", "technical_design", "code_review", "test_report", "build_report", "monitoring_report"], "runtime_inputs": ["project_id"] },
      "outputs": { "documents": ["compiled_documents"], "workspace_files": ["docs/compiled_documents.md"] },
      "responsibilities": ["Compile approved pipeline documents", "Preserve document order", "Produce a review-ready project packet"],
      "handoff": { "next_agent": null, "review_gate": false, "failure_action": "mark documentation task failed" },
      "workspace": { "home_zone": "documentation_room", "writes_to": ["docs/compiled_documents.md"] }
    },
    {
      "id": "pm-agent",
      "name": "PM Agent",
      "role": "project_manager",
      "layer": "on_demand",
      "step": { "name": "pm_summary", "order": 0, "total": 11, "auto_chain": false },
      "model": { "provider": "ollama", "default": "qwen3:8b" },
      "inputs": { "required_documents": [], "optional_documents": ["requirement_summary", "brd", "fsd", "technical_design", "test_report", "build_report", "monitoring_report"], "runtime_inputs": ["project_id"] },
      "outputs": { "documents": ["project_summary", "delivery_report"], "workspace_files": ["docs/project_summary.md", "docs/delivery_report.md"] },
      "responsibilities": ["Summarize scope and delivery status", "Report risks and next actions", "Prepare management-facing delivery report"],
      "handoff": { "next_agent": null, "review_gate": false, "failure_action": "mark PM task failed" },
      "workspace": { "home_zone": "pm_room", "writes_to": ["docs/project_summary.md", "docs/delivery_report.md"] }
    }
  ]
}
